# Copy to .env and fill in. Only OPENAI_API_KEY is required.

# --- Required ---
OPENAI_API_KEY=sk-...

# --- Optional (sensible defaults shown) ---
# Any OpenAI model with tool/function calling support.
OPENAI_MODEL=gpt-4o-mini

# Port the agent's API + dashboard are served on.
PORT=8080

# How long (ms) to wait for a human to approve a gated tool before failing closed.
APPROVAL_TIMEOUT_MS=60000
